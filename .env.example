# Firebase — Firebase Console > 프로젝트 설정 > 일반 > 내 앱 에서 확인
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# OpenAI (5단계) — https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=

# Google Maps — 웹 지도 + Android 네이티브 지도
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# EAS (9단계) — `eas init` 후 Expo 대시보드에서 projectId 확인
# app.json extra.eas.projectId 또는 아래 변수에 동일 값 입력
EAS_PROJECT_ID=

# ── EAS Build 배포 순서 ──
# 1. npm install
# 2. npx eas login
# 3. npx eas init          → projectId를 app.json / EAS_PROJECT_ID에 반영
# 4. npx eas env:create    → Firebase·OpenAI·Maps 키를 production 환경에 등록
# 5. npx eas build --profile preview --platform android   (Android APK 내부 테스트)
#    또는: npm run eas:build:preview:android
